.git
.gitignore
.pytest_cache
__pycache__
*.pyc
*.pyo
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
.codex_tmp*
.manual_tmp*
manual_regression_runs*
manual_regression_tmp
tmp_manual_verify
tmpr*
storage/outputs/*
!storage/outputs/.gitkeep
uploads/*
!uploads/.gitkeep
exports/*
!exports/.gitkeep
data/*
!data/.gitkeep
